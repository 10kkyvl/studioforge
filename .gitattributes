# Normalize to LF in the repository by default, regardless of a contributor's
# core.autocrlf setting. Without this, a Windows contributor can commit CRLF into
# the shell scripts, which then fail to run on macOS and Linux.
* text=auto eol=lf

# Windows-native files keep CRLF in the working tree.
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Shell scripts must stay LF everywhere.
*.sh text eol=lf

# Binary assets: never touch these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.rbxm binary
*.rbxl binary
*.rbxmx binary
*.rbxlx binary

# The embedded SPA build output is generated and committed so `go build` works
# without Node.js. Collapse it in diffs and exclude it from language stats.
internal/webui/dist/** linguist-generated=true
web/package-lock.json linguist-generated=true
